NODE_ENV=development
PORT=3000

# Comma-separated browser origins allowed to call the API (web-admin Vite default: 5173)
CORS_ORIGINS=http://localhost:5173

# Set true to auto-run pending migrations when the API starts (optional; CI runs migration:run explicitly)
TYPEORM_RUN_MIGRATIONS_ON_STARTUP=false

# Prefer pooled URL in production; direct Postgres is fine for local Nest + migrations
DATABASE_URL=postgresql://rezidans:rezidans_dev_pass@localhost:5432/rezidans_dev
# DATABASE_URL=postgresql://rezidans:rezidans_dev_pass@localhost:6432/rezidans_dev

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!!
JWT_ACCESS_EXPIRES_SECONDS=900
# Default 604800 = 7 days
JWT_REFRESH_EXPIRES_SECONDS=604800

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_dev_secret_change_me
S3_BUCKET=rezidans-dev

# Resend (transactional email). Never commit real keys — set RESEND_API_KEY on the server only.
# https://resend.com/docs/send-with-nodejs
RESEND_API_KEY=
# From address: use a domain verified in Resend; for dev you can use onboarding@resend.dev
MAIL_FROM=Sky Wellness <onboarding@resend.dev>
# Optional: shown as Reply-To in members' clients
# MAIL_REPLY_TO=reception@yourclub.com
# Optional: comma-separated inbox list for package-request alerts (overrides administrator users)
# MAIL_SALON_ALERT_EMAILS=desk@club.com,owner@club.com
MAIL_LOCALE=tr-TR
MAIL_TIMEZONE=Europe/Istanbul
