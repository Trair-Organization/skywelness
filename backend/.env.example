NODE_ENV=development
PORT=3000

# Comma-separated browser origins allowed to call the API (web-admin Vite default: 5173)
CORS_ORIGINS=http://localhost:5173

# Set true to auto-run pending migrations when the API starts (optional; CI runs migration:run explicitly)
TYPEORM_RUN_MIGRATIONS_ON_STARTUP=false

# Kullanıcıların yüklediği dosyalar bu dizine kaydedilir. Göreli veya mutlak path kabul edilir.
# Production'da systemd servisinin yazabileceği kalıcı bir dizin önerilir (örn. /var/lib/wellness/uploads).
UPLOAD_DIR=uploads

# Prefer pooled URL in production; direct Postgres is fine for local Nest + migrations.
# Docker Compose Postgres port: 55433 (host çakışmasını önlemek için).
DATABASE_URL=postgresql://rezidans:rezidans_dev_pass@localhost:55433/rezidans_dev
# PgBouncer (transaction pooling) — production'da önerilir:
# DATABASE_URL=postgresql://rezidans:rezidans_dev_pass@localhost:6432/rezidans_dev

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!!
JWT_ACCESS_EXPIRES_SECONDS=900
# Default 604800 = 7 days
JWT_REFRESH_EXPIRES_SECONDS=604800

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_dev_secret_change_me
S3_BUCKET=rezidans-dev

# --- Transactional email -----------------------------------------------------
# Two transports supported. SMTP takes priority when SMTP_HOST is set.
#
# A) SMTP (e.g. Natro xMail). When SMTP_HOST is present, the API uses nodemailer.
# SMTP_HOST=mail.wellnessclub.com
# SMTP_PORT=587            # 587 = STARTTLS (recommended); 465 = implicit TLS
# SMTP_USER=info@wellnessclub.com
# SMTP_PASSWORD=change-me
#
# B) Resend (https://resend.com). Used as fallback when SMTP_HOST is empty.
RESEND_API_KEY=
#
# Display "From" header. With Natro SMTP this MUST match SMTP_USER.
MAIL_FROM=Wellness Club <info@wellnessclub.com>
# Optional: shown as Reply-To in members' clients
# MAIL_REPLY_TO=info@wellnessclub.com
# Optional: comma-separated inbox list for package-request alerts (overrides administrator users)
# MAIL_SALON_ALERT_EMAILS=desk@club.com,owner@club.com
MAIL_LOCALE=tr-TR
MAIL_TIMEZONE=Europe/Istanbul


# ─── SMS Providers ─────────────────────────────────────────
# hybrid = TR numaralar Netgsm, diğerleri Twilio; Netgsm başarısızsa Twilio fallback
# netgsm / twilio = tek sağlayıcıya zorla
SMS_PROVIDER=hybrid

# Netgsm (Türkiye için öncelikli)
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=

# Twilio (uluslararası + Netgsm yedeği)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ─── Stripe Payments ──────────────────────────────────────
# Stripe entegrasyonu opsiyoneldir. Key'ler tanımlı değilse ödeme devre dışı kalır.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
