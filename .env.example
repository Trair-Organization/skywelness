# Copy to .env and adjust. Docker Compose defaults match backend/.env.example.
NODE_ENV=development

# PostgreSQL (direct, dev — Docker Compose port: 55433)
DATABASE_URL=postgresql://rezidans:rezidans_dev_pass@localhost:55433/rezidans_dev

# PostgreSQL via local PgBouncer (transaction pooling)
DATABASE_URL_POOLED=postgresql://rezidans:rezidans_dev_pass@localhost:6432/rezidans_dev

REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_dev_secret_change_me
S3_BUCKET=rezidans-dev
