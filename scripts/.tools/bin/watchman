#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
WATCHMAN_HOME="$ROOT_DIR/scripts/.tools/watchman/watchman-v2023.05.01.00-macos"
WATCHMAN_BIN="$WATCHMAN_HOME/bin/watchman"
STATE_DIR="$ROOT_DIR/scripts/.tools/watchman-state"
SOCK_PATH="$STATE_DIR/watchman.sock"
STATE_FILE="$STATE_DIR/watchman.state"
LOG_FILE="$STATE_DIR/watchman.log"
PID_FILE="$STATE_DIR/watchman.pid"

mkdir -p "$STATE_DIR"
echo "$(date -u +%FT%TZ) watchman-wrapper $*" >> "$STATE_DIR/wrapper.log"
export DYLD_LIBRARY_PATH="$WATCHMAN_HOME/lib:${DYLD_LIBRARY_PATH:-}"

exec "$WATCHMAN_BIN" \
  --unix-listener-path="$SOCK_PATH" \
  --statefile="$STATE_FILE" \
  --logfile="$LOG_FILE" \
  --pidfile="$PID_FILE" \
  "$@"
